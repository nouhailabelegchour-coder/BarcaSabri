# ============================================================
# BarcaSabri — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# Serper.dev API Key — used for real-time Google News search
# Get your free key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# (Optional) Football-Data.org — for live match schedule
# Docs: https://www.football-data.org/documentation/quickstart
# FOOTBALL_DATA_API_KEY=your_football_data_api_key_here
